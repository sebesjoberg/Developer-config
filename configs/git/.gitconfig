[include]
    path = ~/.gitconfig.local

[diff]
    colorMoved = default

[rebase]
    autoStash = true

[fetch]
    prune = false

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true
    default = current

[alias]
    st = status
    co = checkout
    sw = switch
    br = branch
    ci = commit
    amend = commit --amend
    last = log -1 HEAD
    lg = log --graph --decorate --oneline --all
    unstage = restore --staged
    discard = restore
    pf = push --force-with-lease
    aa = add .
    cm = commit -m
    rb = branch -m
    fb = "!f(){ git branch --list \"*$1*\" --format='%(refname:short)'; }; f"
    cleanup = "!f(){ force=0; while [ $# -gt 0 ]; do case \"$1\" in -F|--force) force=1 ;; *) echo \"usage: git cleanup [-F|--force]\" >&2; return 1 ;; esac; shift; done; default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@'); : \"${default:=main}\"; current=$(git branch --show-current); git fetch -p && branches=$(git branch -vv | grep ': gone]' | awk '{print $1}' | grep -vxE \"\\*|$default|$current\"); if [ -z \"$branches\" ]; then echo 'No stale branches to clean up.'; return 0; fi; if [ \"$force\" -eq 1 ]; then echo \"$branches\" | xargs git branch -D; else echo \"$branches\" | xargs git branch -d; fi; }; f"
    aliases = "!f(){ search=''; compact=0; while [ $# -gt 0 ]; do case \"$1\" in --search|-S) shift; if [ $# -eq 0 ]; then echo \"aliases: missing value for search option\" >&2; return 1; fi; search=\"$1\" ;; --compact|-C) compact=1 ;; *) echo \"usage: git aliases [--search|-S <term>] [--compact|-C]\" >&2; return 1 ;; esac; shift; done; print_alias(){ name=\"$1\"; cmd=$(git config --get \"alias.$name\"); desc=$(git config --get \"aliashelp.$name\" 2>/dev/null); if [ -z \"$desc\" ]; then desc=\"(no description)\"; fi; if [ -n \"$search\" ]; then printf '%s %s\\n' \"$name\" \"$cmd\" | grep -Fqi -- \"$search\" || return 0; fi; if [ \"$compact\" -eq 1 ]; then if [ \"$name\" = \"aliases\" ]; then printf '%-12s %s\\n' \"$name\" \"print all aliases\"; else printf '%-12s %s\\n' \"$name\" \"$cmd\"; fi; else echo \"$name\"; echo \"  help: $desc\"; case \"$cmd\" in '!'*) echo \"  command: [shell alias]\" ;; *) echo \"  command: $cmd\" ;; esac; echo; fi; }; names=$(git config --name-only --get-regexp '^alias\\.' | sed 's/^alias\\.//' | sort -u); printf '%s\\n' \"$names\" | while read -r name; do [ -n \"$name\" ] || continue; [ \"$name\" = \"aliases\" ] && continue; print_alias \"$name\"; done; printf '%s\\n' \"$names\" | grep -Fxq aliases && print_alias aliases; }; f"

[aliashelp]
    st = Show working tree status
    co = Checkout branch or paths
    sw = Switch branches
    br = List and manage branches
    ci = Create a commit
    amend = Amend the last commit
    last = Show the latest commit
    lg = Show compact graph log across branches
    unstage = Unstage files
    discard = Discard unstaged worktree changes
    pf = Force push safely with lease
    aa = Stage all current changes
    cm = Commit with message (-m)
    rb = Rename current branch (git rb <new-name>)
    fb = Search local branches by name
    cleanup = Prune remotes and delete local branches whose upstream is gone (-F/--force to delete unmerged too)
    aliases = List git aliases with descriptions and commands (supports --search/-S and --compact/-C)

[core]
    editor = code --wait
    autocrlf = input
    pager = less -FRX

[merge]
    conflictstyle = zdiff3
